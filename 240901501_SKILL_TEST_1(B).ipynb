      "source": [
        "#Solve a System of Linear Equations\n",
        "import numpy as np\n",
        "\n",
        "# Define matrix A\n",
        "A = np.array([[2,3],\n",
        "              [1,2]])\n",
        "\n",
        "# Define vector b\n",
        "b = np.array([8,5])\n",
        "\n",
        "# Solve Ax = b\n",
        "x = np.linalg.solve(A,b)\n",
        "\n",
        "print(\"Solution vector x:\")\n",
        "print(x)"
      ]
    }
  ]
}